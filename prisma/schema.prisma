// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum Role {
  ADMIN
  SALES_MANAGER
  SALES_EXECUTIVE
}

enum LeadStage {
  NEW_LEAD
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum DealStage {
  DISCOVERY
  PROPOSAL
  NEGOTIATION
  CONTRACT_SENT
  CLOSED_WON
  CLOSED_LOST
}

enum LeadSource {
  WEBSITE
  INSTAGRAM
  LINKEDIN
  REFERRAL
  OTHER
}

enum BatchStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}

enum EnrollmentStatus {
  ENROLLED
  IN_PROGRESS
  COMPLETED
  DROPPED
}

enum PlacementStatus {
  NOT_APPLICABLE
  SEARCHING
  PLACED
  SELF_EMPLOYED
}

enum NotificationType {
  FOLLOW_UP
  PAYMENT_DUE
  TRAINING_BATCH
  INACTIVE_LEAD
  SLA_DEADLINE
  SYSTEM
}

// Models
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(SALES_EXECUTIVE)
  serviceId    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  service          Service?         @relation(fields: [serviceId], references: [id])
  assignedLeads    Lead[]           @relation("AssignedLeads")
  assignedDeals    Deal[]           @relation("AssignedDeals")
  salesTargets     SalesTarget[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  mentoredBatches  TrainingBatch[]  @relation("MentoredBatches")

  @@index([serviceId])
  @@index([email])
  @@index([role])
}

model Service {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  // Relations
  users          User[]
  leads          Lead[]
  deals          Deal[]
  trainingBatches TrainingBatch[]

  @@index([slug])
}

model Lead {
  id             String    @id @default(cuid())
  clientName     String
  organization   String?
  email          String
  phone          String?
  stage          LeadStage @default(NEW_LEAD)
  serviceId      String
  source         LeadSource
  assignedToId   String?
  notes          String?   @db.Text
  nextFollowUp   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  service       Service  @relation(fields: [serviceId], references: [id])
  assignedTo    User?    @relation("AssignedLeads", fields: [assignedToId], references: [id])
  deals         Deal[]

  @@index([assignedToId])
  @@index([serviceId])
  @@index([stage])
  @@index([nextFollowUp])
  @@index([source])
}

model Deal {
  id                String     @id @default(cuid())
  leadId            String?
  title             String
  value             Decimal    @db.Decimal(12, 2)
  stage             DealStage  @default(DISCOVERY)
  serviceId         String
  assignedToId      String?
  expectedCloseDate DateTime?
  closedAt          DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Relations
  lead         Lead?    @relation(fields: [leadId], references: [id])
  service      Service  @relation(fields: [serviceId], references: [id])
  assignedTo   User?    @relation("AssignedDeals", fields: [assignedToId], references: [id])

  @@index([assignedToId])
  @@index([serviceId])
  @@index([stage])
  @@index([closedAt])
  @@index([leadId])
}

model SalesTarget {
  id           String   @id @default(cuid())
  userId       String
  month        Int
  year         Int
  targetAmount Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@index([userId])
  @@index([year, month])
}

model TrainingBatch {
  id              String       @id @default(cuid())
  serviceId       String
  batchName       String
  startDate       DateTime
  endDate         DateTime
  mentorId        String?
  maxEnrollments  Int          @default(30)
  status          BatchStatus  @default(UPCOMING)
  createdAt       DateTime     @default(now())

  // Relations
  service      Service      @relation(fields: [serviceId], references: [id])
  mentor       User?        @relation("MentoredBatches", fields: [mentorId], references: [id])
  enrollments  Enrollment[]

  @@index([serviceId])
  @@index([mentorId])
  @@index([status])
  @@index([startDate])
}

model Enrollment {
  id                   String           @id @default(cuid())
  batchId              String
  studentName          String
  email                String
  phone                String?
  progress             Int              @default(0)
  status               EnrollmentStatus @default(ENROLLED)
  certificationIssued  Boolean          @default(false)
  placementStatus      PlacementStatus  @default(NOT_APPLICABLE)
  enrolledAt           DateTime         @default(now())

  // Relations
  batch TrainingBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([status])
  @@index([email])
}

model Notification {
  id                 String           @id @default(cuid())
  userId             String
  title              String
  message            String           @db.Text
  type               NotificationType
  isRead             Boolean          @default(false)
  relatedEntityId    String?
  relatedEntityType  String?
  createdAt          DateTime         @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String
  action       String
  entityType   String
  entityId     String?
  previousData Json?
  newData      Json?
  ipAddress    String?
  createdAt    DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
